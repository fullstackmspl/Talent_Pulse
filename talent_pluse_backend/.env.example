ADMIN_PASSWORD=ChangeMe123!

# --------------------------------------------------
# Django
# --------------------------------------------------
DJANGO_SECRET_KEY=change_this_django_secret_key
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=UTC

# --------------------------------------------------
# Database
# sqlite / postgres / mysql
# --------------------------------------------------
DB_ENGINE=sqlite

# PostgreSQL Example
# DB_ENGINE=postgres
# DB_NAME=talentpulse
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# MySQL Example
# DB_ENGINE=mysql
# DB_NAME=talentpulse
# DB_USER=root
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=3306

# --------------------------------------------------
# Upload Limits
# --------------------------------------------------
